# OpenRouter (required for agent runs)
OPENROUTER_API_KEY=

# Game API (capstone-game backend)
GAME_API_BASE_URL=http://127.0.0.1:8000

# Agent backend
DATABASE_URL=sqlite:///./agent.db
CHROMA_PERSIST_DIR=./chroma_db
CORS_ORIGINS=http://localhost:5174

# Models (OpenRouter slugs)
DEFAULT_EXPLORER_MODEL=google/gemini-2.5-flash
DEFAULT_MEMORY_MODEL=google/gemini-2.5-flash
AVAILABLE_MODELS=google/gemini-2.5-flash,google/gemini-2.5-flash-lite,openai/gpt-4o-mini,openai/gpt-5.5,anthropic/claude-3-5-haiku,anthropic/claude-haiku-4-5,anthropic/claude-opus-4.7,z-ai/glm-5.2

# Optional: Mistral Moderation (blocks suspicious agent commands)
MISTRAL_API_KEY=

# Run defaults
DEFAULT_MAX_STEPS=80
# Idle timeout in seconds: no agent activity at all (not total round duration)
LLM_ROUND_TIMEOUT_SEC=180
AGENT_STUCK_IDLE_SEC=30

# Optional: skip clickwrap file (CI/automation). Otherwise accept via dashboard or CLI.
# DISCLAIMER_ACCEPTED=1
